#!/bin/sh

info=$(git rev-parse --git-dir --show-toplevel --show-prefix \
	--abbrev-ref HEAD 2>/dev/null) || exit 1

{
	read -r git_dir
	read -r toplevel
	read -r prefix
	read -r branch
} <<EOF
$info
EOF

# Detached HEAD: abbrev-ref gives "HEAD", so fall back to the short sha
[ "$branch" = HEAD ] && branch=$(git rev-parse --short HEAD 2>/dev/null)

if [ -d "$git_dir/rebase-merge" ] || [ -d "$git_dir/rebase-apply" ]; then
	state='|REBASE'
elif [ -f "$git_dir/MERGE_HEAD" ]; then
	state='|MERGE'
elif [ -f "$git_dir/CHERRY_PICK_HEAD" ]; then
	state='|PICK'
fi

git diff-index --quiet HEAD -- 2>/dev/null || modified='*'

# cwd rooted at the repo: "reponame/sub/dir", or just "reponame" at the top.
root=${toplevel##*/}
prefix=${prefix%/}
[ -n "$prefix" ] && root="$root/$prefix"

printf '%s\n%s%s%s\n' "$root" "$branch" "$modified" "$state"
