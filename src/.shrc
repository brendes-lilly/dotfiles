HISTCONTROL=ignoredups
[ "$KSH_VERSION" ] && HISTFILE=$XDG_STATE_HOME/ksh_history
[ "$TERMUX_VERSION" ] && _ls_flags=--color=never

_gitinfo() {
	typeset b
	b=$(gitinfo 2>/dev/null)
	[ -n "$b" ] || return
	printf "${1:- [%s]}" "$b"
}

_ls () {
	LC_COLLATE=C \ls -AF $_ls_flags "$@"
}

P=
if [ "$CODESPACES" ]; then
	P="${CODESPACE_NAME%-*}:"
elif [ "$SSH_CONNECTION" ]; then
	P="${LOGNAME}@${HOST:-$HOSTNAME}:"
fi

alias ..='cd ..'
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'
alias l=_ls
alias lc=_ls
alias ls='_ls'
alias ll='_ls -l'
alias lt='ls -ltr'

case $TERM in
dumb)
	set +o emacs +o vi
	case $INSIDE_EMACS in
	*comint)
		stty -echo
		PS1=$(printf '\033]0;\\w$(_gitinfo)\007\033]7;file://\\H\\w\007%% ')
		;;
	*)
		PS1="$P"'\w$(_gitinfo) % '
	esac
	;;
*)
	alias v=$EDITOR
	alias view="$EDITOR -R"
	PS1='\[\e]0;'"$P"'\w$(_gitinfo)\a\]% '
	set -o vi
esac

if [ "$termprog" ] || [ "$winid" ]; then
	. 9
	cdawd() { 9 cd "$@" && awd; }
	alias cd=cdawd
	alias ls='9 ls -F'
	alias ll='9 ls -Fl'
	alias lt='9 ls -Flrt'
	alias lc='9 lc -F'
	unalias rm
	PS1=': $0$(_gitinfo ":%s") ; '
	awd
fi

[ -r "$XDG_CONFIG_HOME/shrc" ] && . "$XDG_CONFIG_HOME/shrc"
