#!/bin/sh
if [ $# -ne 2 ]; then
  echo "Print markdown list of merges into your branch since the last one for easy pasting into a GitHub PR message."
  echo
  echo "Usage: $(basename $0) <dest-branch> <src-branch>"
  echo "Example: $(basename $0) prod dev"
  exit 1
fi

dest=$1
src=$2

is_gh() {
	git config --get-regexp '^remote\..*\.url' 2>/dev/null |
		grep -qi github.com
}

merges() {
	git log "origin/$dest..origin/$src" --merges --pretty=format:'%h %s'
}

if is_gh; then
	merges | grep -i 'pull request'
else
	merges
fi
